generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id                    String   @id @default(cuid())
  email                 String   @unique
  password              String
  name                  String?
  slack_id              String?
  mobile_number         String?
  role                  String   @default("EMPLOYEE")
  remarks               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  remoteWorkStatuses    RemoteWorkStatus[]
  assetAssignments      AssetAssignment[]
  aiSubscriptionAssignments AISubscriptionAssignment[]
  parkingPermits        ParkingPermit[]
  
  assetAssignmentArchives AssetAssignmentArchive[]
  aiSubscriptionAssignmentArchives AISubscriptionAssignmentArchive[]
  parkingPermitArchives ParkingPermitArchive[]

  auditsTriggered       AuditLog[]
}

model RemoteWorkStatus {
  id          String    @id @default(cuid())
  employeeId  String
  employee    Employee  @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Asset {
  id                String   @id @default(cuid())
  assetTag          String?  @unique
  assetType         String   // 'LAPTOP' or 'OTHER'
  serialNumber      String?
  model             String?
  description       String?
  specsRam          String?
  specsHdd          String?
  specsOs           String?
  costInr           Float?
  costEur           Float?
  procurementSource String?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignments       AssetAssignment[]
  assignmentArchives AssetAssignmentArchive[]
}

model AISubscriptionRegister {
  id                String   @id @default(cuid())
  planIdentifier    String?
  subscriptionName  String
  subscriptionTier  String?
  url               String?
  renewalDate       DateTime?
  costInr           Float?
  costEur           Float?
  procurementSource String?
  remarks           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignments       AISubscriptionAssignment[]
  assignmentArchives AISubscriptionAssignmentArchive[]
}

model AssetAssignment {
  id                String   @id @default(cuid())
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id])
  assignedDatetime  DateTime @default(now())
  remarks           String?
}

model AISubscriptionAssignment {
  id                       String                 @id @default(cuid())
  employeeId               String
  employee                 Employee               @relation(fields: [employeeId], references: [id])
  subscriptionId           String
  subscription             AISubscriptionRegister @relation(fields: [subscriptionId], references: [id])
  assignedDatetime         DateTime               @default(now())
  tokensExhaustedDatetime  DateTime?
  remarks                  String?
}

model ParkingPermit {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  permitNumber  String
  vehicleType   String
  issueDate     DateTime
  endDate       DateTime?
  remarks       String?
}

model AssetAssignmentArchive {
  id                String   @id
  employeeId        String
  employee          Employee @relation(fields: [employeeId], references: [id])
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id])
  assignedDatetime  DateTime
  returnedDatetime  DateTime @default(now())
  remarks           String?
}

model AISubscriptionAssignmentArchive {
  id                       String                 @id
  employeeId               String
  employee                 Employee               @relation(fields: [employeeId], references: [id])
  subscriptionId           String
  subscription             AISubscriptionRegister @relation(fields: [subscriptionId], references: [id])
  assignedDatetime         DateTime
  tokensExhaustedDatetime  DateTime?
  returnedDatetime         DateTime               @default(now())
  remarks                  String?
}

model ParkingPermitArchive {
  id            String   @id
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  permitNumber  String
  vehicleType   String
  issueDate     DateTime
  endDate       DateTime?
  archivedDatetime DateTime @default(now())
  remarks       String?
}

model AuditLog {
  id                    String   @id @default(cuid())
  tableName             String
  recordId              String
  action                String
  oldData               String?
  newData               String?
  changedByEmployeeId   String?
  changedByEmployee     Employee? @relation(fields: [changedByEmployeeId], references: [id])
  changedAt             DateTime @default(now())
}

model SystemSettings {
  key   String @id
  value String
}
